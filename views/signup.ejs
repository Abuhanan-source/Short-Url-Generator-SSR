<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up</title>
    <style>
        :root {
            --bg: #eef4ff;
            --surface: #ffffff;
            --border: rgba(79, 109, 255, 0.18);
            --text: #111827;
            --muted: #64748b;
            --primary: #4f6dff;
            font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            background: linear-gradient(180deg, #eef4ff 0%, #fbfcff 100%);
            color: var(--text);
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 24px;
        }

        .page {
            width: min(100%, 460px);
            background: var(--surface);
            border: 1px solid rgba(15, 23, 42, 0.08);
            border-radius: 28px;
            box-shadow: 0 30px 55px rgba(15, 23, 42, 0.08);
            overflow: hidden;
        }

        .content {
            padding: 34px 28px 28px;
        }

        .content h1 {
            margin: 0 0 10px;
            font-size: 2rem;
        }

        .content p {
            margin: 0 0 28px;
            color: var(--muted);
            line-height: 1.7;
        }

        form {
            display: grid;
            gap: 18px;
        }

        label {
            font-weight: 700;
            color: #1f2937;
        }

        input {
            width: 100%;
            padding: 16px 18px;
            border: 1px solid var(--border);
            border-radius: 16px;
            background: #f8fbff;
            color: var(--text);
            font-size: 1rem;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        input:focus {
            outline: none;
            border-color: rgba(79, 109, 255, 0.38);
            box-shadow: 0 0 0 6px rgba(79, 109, 255, 0.12);
        }

        button {
            width: 100%;
            padding: 16px 18px;
            border: none;
            border-radius: 18px;
            background: linear-gradient(135deg, #4f6dff, #6f87ff);
            color: white;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        button:hover {
            transform: translateY(-1px);
            box-shadow: 0 18px 36px rgba(79, 109, 255, 0.24);
        }

        .footer {
            text-align: center;
            margin-top: 12px;
            color: var(--muted);
            font-size: 0.95rem;
        }

        .footer a {
            color: #4f6dff;
            text-decoration: none;
            font-weight: 700;
        }
    </style>
</head>
<body>
    <div class="page">
        <div class="content">
            <h1>Create your account</h1>
            <p>Sign up and start generating short URLs with your own account.</p>
            <form method="post" action="/auth/signup">
                <div>
                    <label for="username">Username</label>
                    <input id="username" type="text" name="username" placeholder="Enter your username" required>
                </div>
                <div>
                    <label for="email">Email</label>
                    <input id="email" type="email" name="email" placeholder="Enter your email" required>
                </div>
                <div>
                    <label for="password">Password</label>
                    <input id="password" type="password" name="password" placeholder="Enter your password" required>
                </div>
                <button type="submit">Sign Up</button>
            </form>
            <div class="footer">
            <span>Don&apos;t have an account? </span><a href="/auth/Userlogin">Log in</a>
        </div>
        </div>
    </div>

    <% if (locals.message) { %>
<script>
    alert("<%= locals.message %>");
</script>
<% } %>
</body>
</html>