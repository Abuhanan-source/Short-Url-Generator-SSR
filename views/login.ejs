<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <style>
        :root {
            --bg: #eef4ff;
            --surface: #ffffff;
            --surface-soft: #f8fbff;
            --primary: #4f6dff;
            --primary-soft: #e7edff;
            --text: #111827;
            --muted: #64748b;
            --border: rgba(79, 109, 255, 0.18);
            font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            background: radial-gradient(circle at top left, rgba(79, 109, 255, 0.16), transparent 28%),
                        radial-gradient(circle at bottom right, rgba(83, 83, 255, 0.12), transparent 28%),
                        var(--bg);
            display: grid;
            place-items: center;
            color: var(--text);
        }

        .login-wrap {
            width: min(100%, 420px);
            background: rgba(255, 255, 255, 0.88);
            border: 1px solid rgba(15, 23, 42, 0.08);
            border-radius: 32px;
            box-shadow: 0 30px 60px rgba(15, 23, 42, 0.12);
            padding: 36px 32px;
            backdrop-filter: blur(18px);
        }

        .brand {
            text-align: center;
            margin-bottom: 28px;
        }

        .brand h1 {
            margin: 0;
            font-size: 2rem;
            letter-spacing: -0.04em;
        }

        .brand p {
            margin: 10px auto 0;
            color: var(--muted);
            max-width: 300px;
            line-height: 1.6;
        }

        form {
            display: grid;
            gap: 18px;
        }

        label {
            display: inline-block;
            font-weight: 700;
            margin-bottom: 6px;
            color: #1f2937;
        }

        input {
            width: 100%;
            padding: 16px 18px;
            border: 1px solid var(--border);
            border-radius: 16px;
            background: var(--surface-soft);
            color: var(--text);
            font-size: 1rem;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        input:focus {
            outline: none;
            border-color: rgba(79, 109, 255, 0.38);
            box-shadow: 0 0 0 6px rgba(79, 109, 255, 0.12);
        }

        button {
            width: 100%;
            padding: 16px 18px;
            border: none;
            border-radius: 18px;
            background: linear-gradient(135deg, #4f6dff, #6f87ff);
            color: white;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        button:hover {
            transform: translateY(-1px);
            box-shadow: 0 18px 36px rgba(79, 109, 255, 0.24);
        }

        .footer {
            text-align: center;
            margin-top: 12px;
            color: var(--muted);
            font-size: 0.95rem;
        }

        .footer a {
            color: #4f6dff;
            text-decoration: none;
            font-weight: 700;
        }

        .error-msg {
            margin-bottom: 16px;
            padding: 12px 14px;
            border-radius: 12px;
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fecaca;
            font-size: 0.95rem;
        }
    </style>
</head>
<body>

    

    <div class="login-wrap">
        <div class="brand">
            <h1>Welcome Back</h1>
            <p>Sign in to access your URL generator dashboard and history.</p>
        </div>
        <form method="post" action="/auth/login">
            <div>
                <label for="email">Email</label>
                <input id="email" type="email" name="email" placeholder="Enter your email" required>
            </div>
            <div>
                <label for="password">Password</label>
                <input id="password" type="password" name="password" placeholder="Enter your password" required>
            </div>
            <button type="submit">Login</button>
        </form>
        <div class="footer">
            <span>Don&apos;t have an account? </span><a href="/auth/Usersignup">Sign up</a>
        </div>
    </div>

   <% if (locals.message) { %>
<script>
    alert("<%= locals.message %>");
</script>
<% } %>


</body>
</html>