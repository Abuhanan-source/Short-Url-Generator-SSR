<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URL Generator Page</title>
    <style>
        :root {
            --bg: #eef4ff;
            --surface: #ffffff;
            --surface-strong: #f8fbff;
            --primary: #4f6dff;
            --primary-soft: #e7edff;
            --accent: #ff7a72;
            --text: #111827;
            --muted: #6b7280;
            --border: rgba(15, 23, 42, 0.08);
            --shadow: 0 24px 64px rgba(15, 23, 42, 0.08);
            font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            font-size: 16px;
        }

        * {
            box-sizing: border-box;
        }

        html,
        body {
            margin: 0;
            min-height: 100%;
            background: radial-gradient(circle at top left, rgba(79, 109, 255, 0.16), transparent 35%),
                        radial-gradient(circle at bottom right, rgba(255, 122, 114, 0.14), transparent 30%),
                        var(--bg);
            color: var(--text);
        }

        body {
            line-height: 1.6;
        }

        .page-wrap {
            max-width: 1140px;
            margin: 0 auto;
            padding: 36px 24px 48px;
        }

        header {
            display: grid;
            gap: 18px;
            margin-bottom: 28px;
        }

        header h1 {
            margin: 0;
            font-size: clamp(2rem, 3vw, 3.2rem);
            letter-spacing: -0.05em;
            line-height: 1.05;
        }

        header p {
            margin: 0;
            color: var(--muted);
            max-width: 720px;
            font-size: 1rem;
        }

        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 30px;
            box-shadow: var(--shadow);
            padding: 32px;
            margin-bottom: 24px;
        }

        .shorten-form {
            display: grid;
            gap: 16px;
        }

        .shorten-form label {
            display: inline-flex;
            font-weight: 700;
            color: var(--text);
        }

        .shorten-form input {
            width: 100%;
            padding: 16px 20px;
            border: 1px solid rgba(79, 109, 255, 0.18);
            border-radius: 18px;
            background: var(--surface-strong);
            color: var(--text);
            font-size: 1rem;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        .shorten-form input:focus {
            outline: none;
            border-color: rgba(79, 109, 255, 0.38);
            box-shadow: 0 0 0 4px rgba(79, 109, 255, 0.12);
        }

        .button-row {
            display: flex;
            justify-content: flex-start;
        }

        .shorten-form button {
            padding: 16px 28px;
            border: none;
            border-radius: 18px;
            background: linear-gradient(135deg, #4f6dff, #6f87ff);
            color: white;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
        }

        .shorten-form button:hover {
            transform: translateY(-1px);
            box-shadow: 0 18px 42px rgba(79, 109, 255, 0.22);
            opacity: 0.98;
        }

        .notice {
            margin-top: 20px;
            padding: 24px 26px;
            border-radius: 22px;
            background: linear-gradient(90deg, rgba(79, 109, 255, 0.1), rgba(255, 255, 255, 0));
            border: 1px solid rgba(79, 109, 255, 0.22);
            color: var(--text);
        }

        .notice strong {
            display: block;
            margin-bottom: 8px;
            color: #0f172a;
        }

        .short-url-link {
            color: #3b5bff;
            font-weight: 700;
            text-decoration: none;
        }

        .navbar {
            display: flex;
            justify-content: flex-end;
            gap: 16px;
            align-items: center;
            width: 100%;
            padding: 18px 0;
        }

        .nav-link {
            color: var(--muted);
            text-decoration: none;
            font-weight: 600;
            padding: 10px 16px;
            border-radius: 999px;
            transition: background 0.2s ease, color 0.2s ease;
        }

        .nav-link:hover {
            background: rgba(79, 109, 255, 0.08);
            color: #3443ff;
        }

        .history-header {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 24px;
        }

        .history-title {
            margin: 0;
            font-size: 1.3rem;
        }

        .history-meta {
            margin: 8px 0 0;
            color: var(--muted);
            font-size: 0.96rem;
        }

        .btn-secondary {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 14px 24px;
            background: #3443ff;
            color: white;
            border-radius: 999px;
            text-decoration: none;
            font-weight: 700;
            transition: transform 0.2s ease, background 0.2s ease;
        }

        .btn-secondary:hover {
            transform: translateY(-1px);
            background: #2235d8;
        }

        .table-wrap {
            overflow-x: auto;
            border-radius: 24px;
        }

        table {
            width: 100%;
            border-spacing: 0;
            min-width: 680px;
            background: var(--surface);
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 18px 48px rgba(15, 23, 42, 0.06);
        }

        thead {
            background: #f3f7ff;
        }

        th,
        td {
            padding: 18px 22px;
            text-align: left;
        }

        th {
            font-size: 0.92rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #475569;
            font-weight: 700;
        }

        tbody tr {
            transition: background 0.2s ease;
        }

        tbody tr:nth-child(even) {
            background: #f8fbff;
        }

        tbody tr:hover {
            background: rgba(79, 109, 255, 0.08);
        }

        td a {
            color: #3b5bff;
            text-decoration: none;
            font-weight: 600;
        }

        .timestamp-cell {
            min-width: 210px;
        }

        .timestamp-list {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .timestamp-chip {
            display: inline-flex;
            align-items: center;
            padding: 7px 12px;
            border-radius: 999px;
            background: rgba(79, 109, 255, 0.12);
            color: #334155;
            font-size: 0.86rem;
            line-height: 1.4;
        }

        .empty-state {
            padding: 28px;
            text-align: center;
            color: var(--muted);
            font-style: italic;
        }

        @media (max-width: 820px) {
            .page-wrap {
                padding: 24px 16px 40px;
            }

            .card {
                padding: 26px;
            }

            th,
            td {
                padding: 14px 16px;
            }
        }

        @media (max-width: 640px) {
            .history-header {
                flex-direction: column;
                align-items: stretch;
            }

            .shorten-form button {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="page-wrap">
        <header>
            <div class="navbar">
                <!-- <a class="nav-link" href="/profile">Profile</a> -->
                <a class="nav-link" href="/auth/signout">Sign Out</a>
            </div>
            <div>
                <h1>URL Generator</h1>
                <p>Paste a long URL, generate a shortened link in seconds, and track click history from the table below.</p>
            </div>
        </header>

        <section class="card">
            <form class="shorten-form" method="post" action="/url/generateURl">
                <label for="url">Enter URL to shorten</label>
                <input id="url" type="text" name="url" placeholder="https://example.com/very-long-url" required>
                <button type="submit">Shorten URL</button>
            </form>

            <% if (locals.shortUrl) { %>
                <div class="notice">
                    <strong>Success!</strong> Your short URL is ready:
                    <div><a class="short-url-link" href="<%= locals.shortUrl %>" target="_blank"><%= locals.shortUrl %></a></div>
                </div>
            <% } %>
        </section>

        <section class="card">
            <div class="history-header">
                <div>
                    <h2 class="history-title">Your URL Click History</h2>
                    <p style="margin: 6px 0 0; color: var(--muted);">View every shortened URL and its click activity.</p>
                </div>
                <a class="btn-secondary" href="/url/history">Show History</a>
            </div>

            <% if (locals.urlClickTimestamps) { %>
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Shortened URL</th>
                                <th>Created At</th>
                                <th>Total Clicks</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (locals.urlClickTimestamps.length > 0) { %>
                                <% locals.urlClickTimestamps.forEach(url => { %>
                                    <tr>
                                        <td><a href="<%= url.shortUrl %>" target="_blank"><%= url.shortUrl %></a></td>
                                        <td class="timestamp-cell">
                                            <div class="timestamp-list">
                                                <% url.timestamps.forEach(timestamp => { %>
                                                    <span class="timestamp-chip"><%= timestamp %></span>
                                                <% }) %>
                                            </div>
                                        </td>
                                        <td><%= url.totalClick %></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td class="empty-state" colspan="3">No URL click history available yet.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </section>
    </div>
</body>
</html>